# F-Droid & Security (¡Nunca subir claves de firma ni ficheros de configuración sensibles!)
*.jks
*.keystore
signing.properties
google-services.json
fabric.properties

# Gradle
.gradle/
build/
*/build/
gradle-app.setting

# Excepciones para Gradle Wrapper (Obligatorio en F-Droid para poder compilar)
!gradle/wrapper/gradle-wrapper.jar
!gradle-wrapper.jar
!gradle-wrapper.properties

# Archivos de configuración local (rutas del SDK de Android, etc.)
local.properties

# Android Studio / IntelliJ IDEA / VS Code
.idea/
*.iml
*.iws
*.ipr
.vscode/

# SO y otros
.DS_Store
Thumbs.db

# Binarios y compilados (F-Droid NO permite binarios pre-compilados en el repo)
*.class
*.apk
*.aab
*.ap_
*.dex
*.obf
*.orig
*.so
*.jar
*.aar

# NDK
obj/

# Entornos y cachés de Python (para los scripts locales)
venv/
.venv/
__pycache__/
*.pyc

# Archivos de prueba y temporales locales
app/release/baselineProfiles/0/app-release.dm
app/release/baselineProfiles/1/app-release.dm
scratch*.kt
scratch*.py
test_*.py
test_*.kt
*.html

# Variables de entorno y secretos locales
.env
cookies.txt
.idea/caches/deviceStreaming.xml
update_strings.py
app/release/baselineProfiles/0/app-release.dm
app/release/output-metadata.json
.idea/caches/deviceStreaming.xml
